{
  "rules": {
    "accounts": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
        "role": {
          ".write": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || (auth.uid === $uid && !data.exists()))"
        }
      }
    },

    "members": {
      ".read": true,
      ".write": "auth != null"
    },

    "events": {
      ".read": true,
      ".write": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')"
    },

    "siteConfig": {
      ".read": true,
      ".write": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')"
    },

    "waitlist": {
      ".read": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
      "$event": {
        "$entry": {
          ".write": "!data.exists() || (auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin'))",
          ".validate": "newData.hasChild('email') && newData.child('email').isString()"
        }
      }
    },

    "attendance": {
      ".read": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "attendees": {
      ".read": true,
      "$event": {
        "$id": {
          ".write": "auth != null && ((auth.uid === $id && (!newData.exists() || newData.child('status').val() !== 'confirmed')) || root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
          ".validate": "newData.hasChild('at') && !newData.hasChild('email')"
        }
      }
    },

    "chat": {
      ".read": "auth != null",
      "$room": {
        "$msg": {
          ".write": "auth != null && (data.exists() ? (data.child('uid').val() === auth.uid || root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin') : (newData.child('uid').val() === auth.uid && (!root.child('chatMutes').child(auth.uid).child('until').exists() || root.child('chatMutes').child(auth.uid).child('until').val() <= now) && !newData.child('text').val().matches(/fuck|shit|bitch|asshole|cunt/i)))",
          ".validate": "newData.hasChildren(['uid','text','at']) && newData.child('uid').val() === auth.uid && newData.child('text').isString() && newData.child('text').val().length <= 500"
        }
      }
    },

    "chatReactions": {
      ".read": "auth != null",
      "$room": {
        "$msg": {
          "$emoji": {
            "$uid": {
              ".write": "auth != null && $uid === auth.uid",
              ".validate": "newData.isBoolean()"
            }
          }
        }
      }
    },

    "chatMutes": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChild('until') && newData.child('until').isNumber()"
      }
    },

    "chatReports": {
      ".read": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
      "$room": {
        "$msg": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid",
            ".validate": "newData.hasChild('at')"
          }
        }
      }
    },

    "manifesto": {
      ".read": true,
      ".write": "auth != null"
    },

    "mindmap": {
      ".read": true,
      ".write": "auth != null"
    },

    "manifesto-workbook": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "$other": {
      ".read": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
      ".write": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')"
    }
  }
}
