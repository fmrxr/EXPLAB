{
  "rules": {
    "accounts": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
        "role": {
          ".write": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || (auth.uid === $uid && !data.exists()))"
        }
      }
    },

    "members": {
      ".read": true,
      ".write": "auth != null"
    },

    "events": {
      ".read": true,
      ".write": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')"
    },

    "siteConfig": {
      ".read": true,
      ".write": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')"
    },

    "waitlist": {
      ".read": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
      "$event": {
        "$entry": {
          ".write": "!data.exists() || (auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin'))",
          ".validate": "newData.hasChild('email') && newData.child('email').isString()"
        }
      }
    },

    "chat": {
      ".read": "auth != null",
      "$room": {
        "$msg": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['uid','text','at']) && newData.child('uid').val() === auth.uid && newData.child('text').isString() && newData.child('text').val().length <= 500"
        }
      }
    },

    "manifesto": {
      ".read": true,
      ".write": "auth != null"
    },

    "mindmap": {
      ".read": true,
      ".write": "auth != null"
    },

    "manifesto-workbook": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "$other": {
      ".read": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')",
      ".write": "auth != null && (root.child('accounts').child(auth.uid).child('role').val() === 'owner' || root.child('accounts').child(auth.uid).child('role').val() === 'admin')"
    }
  }
}
